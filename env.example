# Copy this file to `.env` and fill in your values.
# Do not commit `.env` (contains secrets).

# Groq (optional: enables Groq-backed models)
GROQ_API_KEY=your_groq_api_key_here
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Ollama (optional overrides for local generation)
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=hermes3:8b

# Prompt/template storage (optional override for SQLite file location)
STORAGE_DB_PATH=prompt-builder/storage.db
